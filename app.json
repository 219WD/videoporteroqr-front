{
  "expo": {
    "name": "QR Door",
    "slug": "video-portore",
    "version": "1.0.0",
    "scheme": "qrdoor",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "package": "com.labs219.qrdoor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE",
        "ACCESS_NETWORK_STATE",
        "MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.labs219.qrdoor",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Esta aplicación necesita acceso a la cámara para videollamadas",
        "NSMicrophoneUsageDescription": "Esta aplicación necesita acceso al micrófono para videollamadas",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21",
            "newArchEnabled": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permite a $(PRODUCT_NAME) acceder a tu cámara para videollamadas.",
          "microphonePermission": "Permite a $(PRODUCT_NAME) acceder a tu micrófono para videollamadas.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#7D1522"
        }
      ]
    ],
    "notification": {
      "icon": "./assets/images/android-icon-monochrome.png",
      "color": "#7D1522"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c25b3c79-2ed8-4e77-ac3c-211cf738f05e"
      }
    },
    "owner": "josescap1"
  }
}
